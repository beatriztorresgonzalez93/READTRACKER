{
  "name": "readtracker-server",
  "version": "1.0.0",
  "description": "Backend API for ReadTracker",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:e2e:db": "vitest run tests/http.e2e.db.test.ts",
    "test:watch": "vitest",
    "smoke:predeploy": "npm run build && npm run test",
    "cleanup:reading-sessions": "node scripts/cleanup-reading-session-duplicates.js"
  },
  "keywords": [
    "readtracker",
    "express",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.1.0",
    "firebase-admin": "^13.6.0",
    "helmet": "^8.1.0",
    "pg": "^8.20.0",
    "stripe": "^22.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "nodemon": "^3.1.14",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
