PORT=4000
CLIENT_ORIGIN=http://localhost:5173
# Opcional: varios orígenes separados por coma (p. ej. producción Vercel + previews)
# CLIENT_ORIGINS=https://tu-app.vercel.app,https://tu-app-git-main-xxx.vercel.app
# Opcional: sufijos de host HTTPS para previews Vercel (cada deploy cambia el subdominio)
# CORS_ORIGIN_SUFFIXES=-tuusuario.vercel.app,-tuusuario-projects.vercel.app
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# Firebase Admin (JSON de cuenta de servicio: Project ID, client_email, private_key)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Usa comillas y \\n para saltos de línea en la clave privada
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n....\\n-----END PRIVATE KEY-----\\n"
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CURRENCY=eur
PRO_ONE_TIME_PRICE_CENTS=1999
PRO_TRIAL_DAYS=30

# Opcional: subida de portadas a S3 (POST /api/v1/uploads/cover con Firebase).
# El IAM user necesita s3:PutObject en arn:aws:s3:::BUCKET/users/*
# Para mostrar portadas en la app sin URLs firmadas por lectura, permite s3:GetObject público en ese prefijo o usa CloudFront.
# AWS_REGION=eu-west-1
# S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
