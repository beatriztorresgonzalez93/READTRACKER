PORT=4000
CLIENT_ORIGIN=http://localhost:5173
# Opcional: varios orígenes separados por coma (p. ej. producción Vercel + previews)
# CLIENT_ORIGINS=https://tu-app.vercel.app,https://tu-app-git-main-xxx.vercel.app
# Opcional: sufijos de host HTTPS para previews Vercel (cada deploy cambia el subdominio)
# CORS_ORIGIN_SUFFIXES=-tuusuario.vercel.app,-tuusuario-projects.vercel.app
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
JWT_SECRET=replace-with-a-secure-random-secret
